# Copiá este archivo a .env (que queda fuera de git) y completá con las credenciales
# reales del OAuth Client ID de Google Cloud Console, tipo "Desktop app".
# Ver docs/google-oauth-setup.md para el paso a paso de cómo conseguirlas.
#
# Sin esto configurado, la app funciona igual con IMAP/POP3 manual — solo el botón
# "Conectar cuenta de Google" queda inhabilitado.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
