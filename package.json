{
  "name": "blaster-email-client",
  "version": "0.2.0",
  "description": "Cliente de email multi-cuenta con agrupación de conversaciones y asistencia de IA (local o en la nube)",
  "main": "./out/main/index.js",
  "private": true,
  "author": {
    "name": "Blaster",
    "email": "charlie@blaster.com.ar"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/charliec114/BlasterEmailClient.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "package": "npm run build && electron-builder --dir",
    "release": "npm run build && electron-builder --publish always",
    "postinstall": "electron-rebuild"
  },
  "build": {
    "appId": "ar.com.blaster.emailclient",
    "productName": "Blaster Email Client",
    "directories": {
      "buildResources": "build"
    },
    "artifactName": "${name}-${version}-${os}-${arch}.${ext}",
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Network",
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity"
    },
    "publish": {
      "provider": "github"
    }
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "dotenv": "^17.4.2",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^7.0.2",
    "vite": "^7.3.6"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "better-sqlite3": "^12.11.1",
    "imapflow": "^1.4.7",
    "mailparser": "^3.9.14",
    "node-pop3": "^0.11.0",
    "nodemailer": "^9.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  }
}
